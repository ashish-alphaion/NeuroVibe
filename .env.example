# Set these in Netlify: Project configuration > Environment variables.
# Never commit real tokens.
SUPABASE_URL=https://your-project-reference.supabase.co
SUPABASE_PUBLISHABLE_KEY=replace-with-your-publishable-key
SUPABASE_SECRET_KEY=replace-with-your-server-only-secret-key
SUPABASE_JWKS_URL=https://your-project-reference.supabase.co/auth/v1/.well-known/jwks.json
DEVICE_TOKEN_PEPPER=replace-with-a-cryptographically-random-64-character-value

# Temporary prototype tokens. DEVICE_API_TOKEN is removed after each device has
# its own enrolled credential. DOCTOR_API_TOKEN is replaced by Supabase Auth.
DEVICE_API_TOKEN=replace-with-a-long-random-device-token
DOCTOR_API_TOKEN=replace-with-a-different-long-random-doctor-token

# Optional browser origin for future cross-origin app/portal calls.
# Same-origin requests and ESP32 requests do not require CORS.
ALLOWED_ORIGIN=https://neurovibeapi.netlify.app
