# Set these in Netlify: Project configuration > Environment variables.
# Never commit real tokens.
DEVICE_API_TOKEN=replace-with-a-long-random-device-token
DOCTOR_API_TOKEN=replace-with-a-different-long-random-doctor-token

# Optional browser origin for future cross-origin app/portal calls.
# Same-origin requests and ESP32 requests do not require CORS.
ALLOWED_ORIGIN=https://neurovibeapi.netlify.app
